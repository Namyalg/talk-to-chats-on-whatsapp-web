{
  "manifest_version": 3,
  "name": "WhatsApp Chat Summarizer",
  "version": "1.0.0",
  "description": "Summarize WhatsApp Web conversations using Chrome's built-in Summarizer API",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["*://web.whatsapp.com/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://web.whatsapp.com/*"],
      "js": ["content/content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
